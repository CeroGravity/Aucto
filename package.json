{
  "name": "aucto",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "node --env-file-if-exists=.env.local node_modules/next/dist/bin/next start",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "tsx scripts/with-test-db.ts -- pnpm exec vitest run",
    "test:e2e": "tsx scripts/with-test-db.ts -- pnpm exec playwright test",
    "test:unit:raw": "vitest run",
    "test:e2e:raw": "playwright test",
    "test:db:setup": "tsx scripts/with-test-db.ts --reset -- node -e \"console.log('test DB ready')\"",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:check": "tsx scripts/db-check.ts",
    "db:seed": "tsx scripts/seed.ts",
    "grant-admin": "tsx scripts/grant-admin.ts"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "1.11.2",
    "@hookform/resolvers": "5.2.2",
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-slot": "1.2.3",
    "@radix-ui/react-switch": "1.2.6",
    "bcryptjs": "3.0.3",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "drizzle-orm": "0.44.6",
    "lucide-react": "0.545.0",
    "next": "15.5.4",
    "next-auth": "5.0.0-beta.29",
    "next-themes": "0.4.6",
    "postgres": "3.4.9",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-hook-form": "7.66.0",
    "tailwind-merge": "3.3.1",
    "three": "^0.184.0",
    "zod": "4.1.12"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@biomejs/biome": "2.3.4",
    "@playwright/test": "1.56.1",
    "@tailwindcss/postcss": "4.1.14",
    "@types/node": "24.9.2",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "@types/three": "^0.184.1",
    "drizzle-kit": "0.31.6",
    "embedded-postgres": "18.3.0-beta.17",
    "lighthouse": "^13.3.0",
    "tailwindcss": "4.1.14",
    "tsx": "4.20.6",
    "tw-animate-css": "1.4.0",
    "typescript": "5.9.3",
    "vitest": "3.2.4"
  }
}
