# Copy to .env.local and fill in real values. Never commit .env.local.

# Pooled Postgres connection (Neon PgBouncer) — used by the app at runtime.
DATABASE_URL=

# Direct (non-pooled) Postgres connection — used for migrations/seed (DDL).
# Optional: tooling derives it from DATABASE_URL by dropping "-pooler" if unset.
DATABASE_URL_UNPOOLED=

# Local test database. Set automatically by the test runner (scripts/with-test-db.ts)
# — you do NOT set this by hand. The suite boots a local embedded Postgres and
# points the app + tooling here, so tests never touch the Neon prod DB above.
# Listed for visibility only.
TEST_DATABASE_URL=

# Auth.js session/JWT secret. Generate with: openssl rand -base64 33
AUTH_SECRET=

# Absolute base URL (used to build payment callback URLs).
APP_URL=http://localhost:3000

# Payment provider: "fake" (default, no network) or "sslcommerz".
PAYMENT_PROVIDER=fake

# SSLCommerz sandbox credentials (register at developer.sslcommerz.com).
SSLCZ_STORE_ID=
SSLCZ_STORE_PASSWD=
SSLCZ_IS_LIVE=false

# Uploaded payment screenshots: "local" (default, disk) or "blob" (deploy).
STORAGE_PROVIDER=local
LOCAL_UPLOAD_DIR=./uploads
# Blob token (deploy only; local adapter ignores it).
BLOB_READ_WRITE_TOKEN=

# Manual payment merchant numbers + contact (public; shown at checkout/receipt).
NEXT_PUBLIC_BKASH_NUMBER=
NEXT_PUBLIC_NAGAD_NUMBER=
NEXT_PUBLIC_FACEBOOK_URL=

# Notifications: "fake" (default, logs only, no network) or "real".
NOTIFY_PROVIDER=fake
# Owner new-order alert via Telegram Bot API (@BotFather token + your chat id).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Customer receipt email via Resend (API key + verified/onboarding sender).
RESEND_API_KEY=
EMAIL_FROM=
