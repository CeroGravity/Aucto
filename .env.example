# Copy to .env.local and fill in real values. Never commit .env.local.

# Pooled Postgres connection (Neon PgBouncer) — used by the app at runtime.
DATABASE_URL=

# Direct (non-pooled) Postgres connection — used for migrations/seed (DDL).
# Optional: tooling derives it from DATABASE_URL by dropping "-pooler" if unset.
DATABASE_URL_UNPOOLED=

# Auth.js session/JWT secret. Generate with: openssl rand -base64 33
AUTH_SECRET=
